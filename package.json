{
  "name": "csh",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ContextVM shell prototype",
  "scripts": {
    "start": "bun run src/main.ts",
    "start:contextvm": "bun run src/contextvm-gateway.ts",
    "start:browser": "bun run src/browser/server.ts",
    "dev": "bun run --watch src/main.ts",
    "demo:local": "bun run src/demo/local-demo.ts",
    "demo:contextvm": "bun run src/contextvm-demo-client.ts",
    "demo:contextvm:interactive": "bun run src/contextvm-interactive-client.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@contextvm/sdk": "^0.7.3",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "typescript": "^5.9.3"
  }
}

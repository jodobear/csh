{
  "name": "csh",
  "private": true,
  "bin": {
    "csh": "./bin/csh"
  },
  "type": "module",
  "scripts": {
    "csh": "bun scripts/phase1/csh.ts",
    "start": "bun run src/main.ts",
    "start:contextvm": "bun run src/contextvm-gateway.ts",
    "start:browser": "bun run src/browser/server.ts",

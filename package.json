{
  "name": "csh",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "csh": "./bin/csh"
  },
  "type": "module",
  "scripts": {
    "csh": "bun scripts/csh.ts",
    "start": "bun run src/main.ts",
    "start:contextvm": "bun run src/contextvm-gateway.ts",
    "start:browser": "bun run src/browser-static/preview-server.ts",
    "start:browser:bridge": "bun run src/browser/server.ts",
    "start:browser:contextvm": "bun run src/browser/contextvm-server.ts",
    "test:phase7-session-contract": "bun test --timeout 15000 src/server/session-contract.test.ts",
    "test:phase7-browser-contract": "bun test --timeout 15000 src/browser/server-core.test.ts",
    "test:phase7-contract": "bun test --timeout 15000 src/server/session-contract.test.ts src/browser/server-core.test.ts",
    "test:host-control": "bun test --timeout 15000 scripts/host-control.test.ts",
    "test:startup-env": "bun test --timeout 15000 scripts/startup-env.test.ts",
    "test:fresh-checkout": "bun test --timeout 15000 scripts/fresh-checkout.test.ts",
    "demo:contextvm:interactive": "bun run src/contextvm-interactive-client.ts",
    "csh:operator": "bash scripts/operator.sh",
    "csh:keys": "bun run scripts/generate-keypair.ts",
    "csh:build-browser": "bun run scripts/build-browser-assets.ts",
    "csh:smoke": "bun run scripts/smoke-client.ts",
    "csh:lifecycle": "bun run scripts/lifecycle-client.ts",
    "csh:idle-expiry": "bun run scripts/idle-expiry.ts",
    "csh:aged-browser-attach": "bun run scripts/aged-browser-attach.ts",
    "csh:restart-recovery": "bun run scripts/restart-recovery.ts",
    "csh:relay-recovery": "bun run scripts/relay-recovery.ts",
    "csh:session-soak": "bun run scripts/session-soak.ts",
    "csh:fresh-checkout": "bun run scripts/fresh-checkout.ts",
    "csh:release-verify": "bun run scripts/release-verify.ts",
    "csh:proxy-smoke": "bun run scripts/proxy-smoke.ts",
    "csh:browser-smoke": "bun run scripts/browser-smoke.ts",
    "csh:invite-onboarding-smoke": "bun run scripts/invite-onboarding-smoke.ts",
    "test:release-verify": "bun test --timeout 15000 scripts/release-verify.test.ts"
  },
  "dependencies": {
    "@contextvm/sdk": "0.7.3",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "nostr-tools": "2.23.3",
    "zod": "4.3.6"
  }
}

# Copy this file to .env.phase1.local and fill in the values before running the csh scripts.
#
# Generate test keypairs with:
#   bun run csh:keys

# Comma-separated relay URLs used by both host and client.
CVM_RELAYS=ws://127.0.0.1:10552

# Host-side gateway identity. This private key is used by the repo-local ContextVM gateway.
GW_PRIVATE_KEY=

# Optional metadata published by the repo-local gateway.
GW_SERVER_INFO_NAME=csh terminal host
GW_SERVER_INFO_WEBSITE=
GW_SERVER_INFO_PICTURE=

# Private-by-default host setting. Keep this at 0 unless you explicitly want an open local test.
GW_ALLOW_UNLISTED_CLIENTS=0

# Comma-separated allowlist of client pubkeys accepted by the host gateway.
GW_ALLOWED_PUBLIC_KEYS=

# Encryption mode accepted by the host and clients: optional, required, or disabled.
GW_ENCRYPTION_MODE=required

# Client-side identity used by the smoke client.
CVM_CLIENT_PRIVATE_KEY=

# The host server public key derived from GW_PRIVATE_KEY.
CVM_SERVER_PUBKEY=

# Optional proxy-side override. Defaults to GW_ENCRYPTION_MODE.
CVM_PROXY_ENCRYPTION_MODE=required

# Default SDK transport log level. Use `error` to suppress reconnect warning noise in normal runs.
CVM_LOG_LEVEL=error

# Client response lookback to tolerate relay or clock skew.
CVM_RESPONSE_LOOKBACK_SECONDS=300

# Persistent shell session ID used by the smoke test.
CVM_SMOKE_SESSION_ID=phase1-smoke

# Separate session ID for reconnect/cleanup lifecycle testing.
CVM_LIFECYCLE_SESSION_ID=phase1-lifecycle

# Browser UI listen address.
CSH_BROWSER_HOST=127.0.0.1
CSH_BROWSER_PORT=4318

# Refuse non-loopback browser binds unless explicitly set to 1.
CSH_BROWSER_ALLOW_REMOTE=0

# Browser UI authentication. Local browser mode should still be treated as authenticated.
CSH_BROWSER_AUTH_USER=csh
CSH_BROWSER_AUTH_PASSWORD=

# Remote browser mode requires an HTTPS/TLS-terminating reverse proxy and explicit opt-in.
CSH_BROWSER_TRUST_PROXY_TLS=0

# Session lifecycle defaults for the tmux-backed server.
CSH_SESSION_IDLE_TTL_SECONDS=1800
CSH_CLOSED_SESSION_TTL_SECONDS=300
